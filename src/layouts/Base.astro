---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daniel Zeng. AI researcher and engineer.' } = Astro.props;
const isBlog = Astro.url.pathname.startsWith('/blog');

// TODO: Resume is a placeholder until a web-ready PDF exists
const links = [
  { label: 'Blog', href: '/blog' },
  { label: 'Resume', href: '#' },
  { label: 'GitHub', href: 'https://github.com/daniel-zeng' },
  { label: 'Scholar', href: 'https://scholar.google.com/citations?user=PpLhFIgAAAAJ' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/daniel-zeng/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header fade" style="--d: 0">
      <a class="name" href="/">Daniel Zeng</a>
      <nav>
        {links.map((l) => (
          <a href={l.href} class={l.href === '/blog' && isBlog ? 'active' : ''}>{l.label}</a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
