---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daniel Zeng. ML researcher and engineer.' } = Astro.props;
const path = Astro.url.pathname;
const isBlog = path.startsWith('/blog');
const canonical = new URL(path, Astro.site);

// Flip to true to show the Home | Blog nav once the blog is real
const SHOW_NAV = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Daniel Zeng" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <header class="site-header fade" style="--d: 0">
      <a class="name" href="/">Daniel Zeng</a>
      {SHOW_NAV && (
        <nav>
          <a href="/" class={!isBlog ? 'active' : ''}>Home</a>
          <a href="/blog" class={isBlog ? 'active' : ''}>Blog</a>
        </nav>
      )}
    </header>
    <main>
      <slot />
    </main>
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "2608e44fa7034ade929eefeeadc9e8d6"}'></script>
  </body>
</html>
