---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daniel Zeng. AI researcher and engineer.' } = Astro.props;
const path = Astro.url.pathname;
const isBlog = path.startsWith('/blog');

// Flip to true to show the Home | Blog nav once the blog is real
const SHOW_NAV = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header fade" style="--d: 0">
      <a class="name" href="/">Daniel Zeng</a>
      {SHOW_NAV && (
        <nav>
          <a href="/" class={!isBlog ? 'active' : ''}>Home</a>
          <a href="/blog" class={isBlog ? 'active' : ''}>Blog</a>
        </nav>
      )}
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
