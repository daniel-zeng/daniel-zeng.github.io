---
import Base from '../layouts/Base.astro';

// TODO: Resume is a placeholder until a web-ready PDF exists
const links = [
  { label: 'Resume', href: '#' },
  { label: 'GitHub', href: 'https://github.com/daniel-zeng' },
  { label: 'Scholar', href: 'https://scholar.google.com/citations?user=PpLhFIgAAAAJ' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/daniel-zeng/' },
];

const ME = 'Daniel Zeng';

const publications = [
  {
    date: '2025 Oct',
    title: 'Pearl: A Foundation Model for Placing Every Atom in the Right Location',
    authors: ['Genesis Research Team'],
    note: 'Technical report',
    href: 'https://arxiv.org/abs/2510.24670',
  },
  {
    date: '2023 May',
    title: 'PRODIGY: Enabling In-context Learning Over Graphs',
    authors: ['Qian Huang', 'Hongyu Ren', 'Peng Chen', 'Gregor Kržmanc', 'Daniel Zeng', 'Percy Liang', 'Jure Leskovec'],
    note: 'NeurIPS 2023 Spotlight',
    href: 'https://arxiv.org/abs/2305.12600',
  },
  {
    date: '2022 Jul',
    title: 'ViRel: Unsupervised Visual Relations Discovery with Graph-level Analogy',
    authors: ['Daniel Zeng', 'Tailin Wu', 'Jure Leskovec'],
    note: 'ICML 2022 Workshop',
    href: 'https://arxiv.org/abs/2207.00590',
  },
];
---

<Base title="Daniel Zeng">
  <section class="fade" style="--d: 1; margin-top: 0;">
    <p>I am an ML researcher and engineer.</p>
    <p>
      From 2023 to 2026, I was at <a href="https://www.genesis.ml/">Genesis Molecular AI</a>, where I worked on machine
      learning for drug discovery. I built data infrastructure for
      <a href="https://arxiv.org/abs/2510.24670">Pearl</a>, a state-of-the-art
      protein folding foundation model, and an active learning platform that
      screens billions of compounds.
    </p>
    <p>
      Before Genesis, I interned at Google Research, distilling vision models for
      efficient serving.
    </p>
    <p>
      I studied computer science at Stanford (MS) and UC Berkeley (BS).
    </p>
    <p class="links-row">
      {links.map((l, i) => (
        <>
          <a href={l.href}>{l.label}</a>
          {i < links.length - 1 && ' / '}
        </>
      ))}
    </p>
  </section>

  <section class="fade" style="--d: 2">
    <h2>Publications</h2>
    <ul class="pubs">
      {publications.map((p) => (
        <li>
          <span class="date">{p.date}</span>
          <span>
            <a href={p.href}>{p.title}</a>
            <p class="meta">
              {p.authors.map((a, i) => (
                <>{i > 0 && ', '}<span class={a === ME ? 'me' : ''}>{a}</span></>
              ))}{' · '}{p.note}
            </p>
          </span>
        </li>
      ))}
    </ul>
  </section>

  <footer class="fade" style="--d: 3">
    <p class="muted">
      Reach me at <a href="https://x.com/danielzeng_">@danielzeng_</a> or on
      <a href="https://www.linkedin.com/in/daniel-zeng/">LinkedIn</a>.
    </p>
  </footer>
</Base>
