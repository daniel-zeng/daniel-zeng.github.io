---
// Throwaway name-font vibe-check page — display serif candidates for the name,
// each over a Palatino body block. Not linked from anywhere. Delete when decided.
const fonts = [
  { name: 'Palatino (same as body — baseline)', stack: "Palatino, 'Palatino Linotype', serif" },
  { name: 'Cormorant Garamond', stack: "'Cormorant Garamond', serif" },
  { name: 'Marcellus', stack: 'Marcellus, serif' },
  { name: 'Playfair Display', stack: "'Playfair Display', serif" },
  { name: 'DM Serif Display', stack: "'DM Serif Display', serif" },
  { name: 'Fraunces', stack: 'Fraunces, serif' },
  { name: 'Libre Caslon Display', stack: "'Libre Caslon Display', serif" },
  { name: 'Cinzel', stack: 'Cinzel, serif' },
  { name: 'Bodoni Moda', stack: "'Bodoni Moda', serif" },
  { name: 'Gilda Display', stack: "'Gilda Display', serif" },
  { name: 'Instrument Serif', stack: "'Instrument Serif', serif" },
  { name: 'Prata', stack: 'Prata, serif' },
  { name: 'Young Serif', stack: "'Young Serif', serif" },
  { name: 'Italiana', stack: 'Italiana, serif' },
  { name: 'Cardo', stack: 'Cardo, serif' },
  { name: 'Sorts Mill Goudy', stack: "'Sorts Mill Goudy', serif" },
  { name: 'EB Garamond', stack: "'EB Garamond', serif" },
  { name: 'Spectral Light', stack: 'Spectral, serif', weight: '300' },
  { name: 'Vollkorn', stack: 'Vollkorn, serif' },
  { name: 'Alegreya Medium', stack: 'Alegreya, serif', weight: '500' },
  { name: 'Old Standard TT', stack: "'Old Standard TT', serif" },
  { name: 'Unna', stack: 'Unna, serif' },
  { name: 'Palatino small caps, letterspaced', stack: "Palatino, 'Palatino Linotype', serif", caps: true },
  { name: 'Cormorant Garamond small caps, letterspaced', stack: "'Cormorant Garamond', serif", caps: true, weight: '500' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Name font vibe check</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=Marcellus&family=Playfair+Display:wght@400;500&family=DM+Serif+Display&family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Libre+Caslon+Display&family=Cinzel:wght@400;500&family=Bodoni+Moda:opsz,wght@6..96,400;6..96,500&family=Gilda+Display&family=Instrument+Serif&family=Prata&family=Young+Serif&family=Italiana&family=Cardo&family=Sorts+Mill+Goudy&family=EB+Garamond:wght@400;500&family=Spectral:wght@300&family=Vollkorn&family=Alegreya:wght@400;500&family=Old+Standard+TT&family=Unna&display=swap"
    />
  </head>
  <body>
    <div class="wrap">
      {fonts.map((f) => (
        <div class="card">
          <p class="label">{f.name}</p>
          <p
            class="name"
            style={`font-family: ${f.stack};${f.weight ? ` font-weight: ${f.weight};` : ''}${f.caps ? ' font-variant: small-caps; letter-spacing: 0.08em;' : ''}`}
          >
            Daniel Zeng
          </p>
          <p>
            I am an AI researcher and engineer.
          </p>
          <p>
            From 2023 to 2026, I was at <a href="#">Genesis Molecular AI</a>, where
            I worked on machine learning for drug discovery. I built data
            infrastructure for <a href="#">Pearl</a>, a state-of-the-art protein
            folding foundation model.
          </p>
        </div>
      ))}
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: #fffefc;
  }

  .wrap {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    color: #1f1f1f;
    font-family: Palatino, 'Palatino Linotype', serif;
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  .card {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid #eee9e2;
  }

  .label {
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #b0a89d;
    margin-bottom: 1.25rem;
  }

  .name {
    font-size: 1.7rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
  }

  p + p {
    margin-top: 0.75rem;
  }

  a {
    color: #1f1f1f;
    text-decoration: underline;
    text-decoration-color: #cfc9c1;
    text-underline-offset: 3px;
  }
</style>
