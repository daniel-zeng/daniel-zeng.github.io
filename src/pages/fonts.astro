---
// Throwaway font vibe-check page — not linked from anywhere. Delete when decided.
// (G) = Google Font, loaded via CDN for preview only; would self-host if chosen.
const fonts = [
  { name: 'Iowan Old Style — CURRENT', stack: "'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia, serif" },
  { name: 'Palatino', stack: "Palatino, 'Palatino Linotype', serif" },
  { name: 'Georgia', stack: 'Georgia, serif' },
  { name: 'Hoefler Text', stack: "'Hoefler Text', serif" },
  { name: 'Baskerville', stack: 'Baskerville, serif' },
  { name: 'Charter', stack: "Charter, 'Bitstream Charter', serif" },
  { name: 'Athelas', stack: 'Athelas, serif' },
  { name: 'New York (ui-serif)', stack: "ui-serif, 'New York', serif" },
  { name: 'EB Garamond (G)', stack: "'EB Garamond', serif" },
  { name: 'Crimson Pro (G)', stack: "'Crimson Pro', serif" },
  { name: 'Source Serif 4 (G)', stack: "'Source Serif 4', serif" },
  { name: 'Lora (G)', stack: 'Lora, serif' },
  { name: 'Newsreader (G)', stack: 'Newsreader, serif' },
  { name: 'Literata (G)', stack: 'Literata, serif' },
  { name: 'Spectral (G)', stack: 'Spectral, serif' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Font vibe check</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital@0;1&family=Crimson+Pro:ital@0;1&family=Source+Serif+4:ital,opsz@0,8..60;1,8..60&family=Lora:ital@0;1&family=Newsreader:ital,opsz@0,6..72;1,6..72&family=Literata:ital,opsz@0,7..72;1,7..72&family=Spectral:ital@0;1&display=swap"
    />
  </head>
  <body>
    <div class="wrap">
    {fonts.map((f) => (
      <div class="card" style={`font-family: ${f.stack}`}>
        <p class="label">{f.name}</p>
        <p class="name">Daniel Zeng</p>
        <p>
          From 2023 to 2026, I was at <a href="#">Genesis Molecular AI</a>, where I
          worked on machine learning for drug discovery. I built data infrastructure
          for <a href="#">Pearl</a>, a state-of-the-art protein folding foundation
          model, and an active learning platform that screened billions of compounds.
        </p>
        <p class="meta">Qian Huang, Hongyu Ren, Peng Chen, Gregor Kržmanc, <span class="me">Daniel Zeng</span>, Percy Liang, Jure Leskovec · NeurIPS 2023 Spotlight</p>
      </div>
    ))}
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: #fffefc;
  }

  .wrap {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    color: #1f1f1f;
    -webkit-font-smoothing: antialiased;
  }

  .card {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid #eee9e2;
    font-size: 17px;
    line-height: 1.65;
  }

  .label {
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #b0a89d;
    margin-bottom: 1.25rem;
  }

  .name {
    font-weight: 600;
    font-size: 1.15rem;
    margin-bottom: 0.75rem;
  }

  p + p {
    margin-top: 0.75rem;
  }

  a {
    color: #1f1f1f;
    text-decoration: underline;
    text-decoration-color: #cfc9c1;
    text-underline-offset: 3px;
  }

  .meta {
    font-size: 0.85rem;
    color: #a8a39c;
  }

  .meta .me {
    color: #6b6b6b;
  }
</style>
